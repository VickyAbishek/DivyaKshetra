{
  "expo": {
    "name": "DivyaKshetra",
    "slug": "divyakshetra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "divyakshetra",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5E6C8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.divyakshetra.app",
      "infoPlist": {
        "NSCameraUsageDescription": "DivyaKshetra needs camera access to photograph sacred places.",
        "NSPhotoLibraryUsageDescription": "DivyaKshetra needs photo library access to attach photos to place submissions.",
        "NSLocationWhenInUseUsageDescription": "DivyaKshetra uses your location to show nearby sacred places.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5E6C8"
      },
      "package": "com.divyakshetra.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-location",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d88f740c-bfea-45e0-abba-45b27a78b064"
      }
    }
  }
}
